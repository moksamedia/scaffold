{
  "name": "scaffold",
  "version": "0.0.1",
  "description": "A powerful hierarchical outline and note-taking application",
  "productName": "Scaffold",
  "author": "Andrew Hughes <andrewcarterhughes@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "quasar dev",
    "build": "quasar build",
    "build:gh-pages": "GITHUB_PAGES=true quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "buffer": "^6.0.3",
    "docx": "^9.5.1",
    "lz-string": "^1.5.0",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "vue": "^3.4.18",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@pinia/testing": "^1.0.3",
    "@quasar/app-vite": "^2.1.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.30.0",
    "globals": "^15.12.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "vite-plugin-checker": "^0.9.0",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
